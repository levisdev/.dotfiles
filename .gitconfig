	email = khoa05032006@gmail.com
	name = levisdev

[init]
	defaultBranch = main

[safe]
    directory = *

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    light = false

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[credential "helperselector"]
	selected = manager
